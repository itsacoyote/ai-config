{
  "statusLine": {
    "type": "command",
    "command": "bash statusline-command.sh"
  },
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git switch *)",
      "Bash(git switch -c *)",
      "Bash(git pull *)",
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(gh pr *)"
    ]
  }
}
